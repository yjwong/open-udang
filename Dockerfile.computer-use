# Container image for computer use (GUI interaction) contexts.
#
# Extends the base sandbox image with a headless Wayland
# compositor (labwc), input injection (wlrctl), screenshot capture
# (grim), VNC server (wayvnc), a web browser (Chromium via Playwright),
# and Playwright MCP for structured browser automation.
#
# Build:
#   docker build -f Dockerfile.computer-use -t openshrimp-computer-use:latest .

FROM openshrimp-claude:latest

# Wayland compositor + tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    labwc \
    wlrctl \
    grim \
    wayvnc \
    wl-clipboard \
    foot \
    # Fonts for readable screenshots
    fonts-liberation \
    fonts-noto-color-emoji \
    fonts-noto \
    # Misc runtime deps
    dbus-x11 \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Build seat-keyboard: persistent virtual keyboard daemon so the Wayland
# seat advertises keyboard capability on headless setups (no physical kbd).
# Without this, Firefox ignores all virtual keyboard input from wlrctl.
COPY computer-use/seat-keyboard.c /tmp/build/seat-keyboard.c
COPY computer-use/virtual-keyboard-unstable-v1.xml /tmp/build/virtual-keyboard-unstable-v1.xml
COPY computer-use/input-method-unstable-v2.xml /tmp/build/input-method-unstable-v2.xml
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libc6-dev \
    libwayland-dev \
    pkg-config \
    && cd /tmp/build \
    && wayland-scanner client-header \
        virtual-keyboard-unstable-v1.xml \
        virtual-keyboard-unstable-v1-client-protocol.h \
    && wayland-scanner private-code \
        virtual-keyboard-unstable-v1.xml \
        virtual-keyboard-unstable-v1-protocol.c \
    && wayland-scanner client-header \
        input-method-unstable-v2.xml \
        input-method-unstable-v2-client-protocol.h \
    && wayland-scanner private-code \
        input-method-unstable-v2.xml \
        input-method-unstable-v2-protocol.c \
    && gcc -Wall -o /usr/local/bin/seat-keyboard \
        seat-keyboard.c \
        virtual-keyboard-unstable-v1-protocol.c \
        input-method-unstable-v2-protocol.c \
        $(pkg-config --cflags --libs wayland-client) \
    && apt-get purge -y gcc libc6-dev libwayland-dev pkg-config \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/* /tmp/build

# Pre-create directories for labwc config and screenshots.
RUN mkdir -p /home/claude/.config/labwc /tmp/screenshots \
    && chmod -R 777 /home/claude/.config /tmp/screenshots

# Copy labwc configuration.
COPY computer-use/rc.xml /home/claude/.config/labwc/rc.xml
COPY computer-use/autostart /home/claude/.config/labwc/autostart

# Copy entrypoint script.
COPY computer-use/entrypoint.sh /usr/local/bin/computer-use-entrypoint.sh
RUN chmod +x /usr/local/bin/computer-use-entrypoint.sh

# Node.js 24 LTS for Playwright MCP.
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Pre-install Playwright MCP and its Chromium browser so the CLI
# doesn't need to download anything at runtime.
RUN npm install -g --cache /tmp/npm-cache @playwright/mcp \
    && npx playwright install --with-deps chromium \
    && rm -rf /tmp/npm-cache \
    && chmod -R 777 /home/claude/.cache \
    && rm -rf /home/claude/.npm && mkdir -p /home/claude/.npm && chmod 777 /home/claude/.npm

# Chromium profile: skip first-run UI and disable crash reporter.
# Playwright installs Chromium under /home/claude/.cache/ms-playwright/.
RUN CHROMIUM_DIR=$(find /home/claude/.cache/ms-playwright -maxdepth 2 -name 'chromium*' -type d | head -1) \
    && mkdir -p /home/claude/.config/chromium/Default \
    && printf '{\n  "browser": { "check_default_browser": false },\n  "profile": { "default_content_setting_values": {} }\n}\n' \
    > /home/claude/.config/chromium/Default/Preferences \
    && printf '%s\n' '{"countrycode_at_install":"","default_browser_infobar_last_declined":"","default_browser_set_once":"","metrics":{"reporting_enabled":false},"session":{"restore_on_startup":4}}' \
    > /home/claude/.config/chromium/'Local State' \
    && chmod -R 777 /home/claude/.config/chromium
