# Custom sandbox container for open-shrimp development.
# Adds uv (Python) and Node.js/npm on top of the base sandbox image.
# BASE_IMAGE is overridden automatically when computer_use is enabled.

ARG BASE_IMAGE=openshrimp-claude:latest
FROM ${BASE_IMAGE}

# Install uv.
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh

# Install Node.js 24 (LTS) via NodeSource.
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Verify installations.
RUN uv --version && node --version && npm --version
