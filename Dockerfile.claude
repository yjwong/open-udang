# Minimal container image for running the Claude Code CLI in isolation.
#
# The bundled CLI is a statically-ish linked native binary (only needs
# glibc/libm/libpthread), so a slim Debian base is sufficient — no
# Node.js required.
#
# Build:
#   docker build -f Dockerfile.claude -t openshrimp-claude:latest \
#     --build-arg CLAUDE_CLI=/path/to/claude .
#
# Or let it auto-detect from an installed claude-agent-sdk:
#   docker build -f Dockerfile.claude -t openshrimp-claude:latest .

FROM debian:trixie-slim

# Install common tools the agent might need (git, curl, etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install rootless Docker dependencies for optional Docker-in-Docker.
# Packages are always installed (small footprint); DinD is activated at
# runtime only when the context has docker_in_docker: true.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        iproute2 \
        procps \
        uidmap \
        fuse-overlayfs \
        slirp4netns \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg \
        -o /etc/apt/keyrings/docker.asc \
    && chmod a+r /etc/apt/keyrings/docker.asc \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] \
        https://download.docker.com/linux/debian trixie stable" \
        > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        docker-ce \
        docker-ce-cli \
        docker-ce-rootless-extras \
        docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*

# Create a home directory for the non-root user.
# The actual uid/gid is set at runtime via --user, but the directory
# must exist and be writable.
RUN mkdir -p /home/claude/.claude /home/claude/.local/share/docker \
        /home/claude/.local/share/opencode \
    && chmod -R 777 /home/claude

# Allow the runtime user (arbitrary uid via --user) to write subuid/subgid
# and passwd/group entries needed by rootless Docker.  Safe in an ephemeral
# container.
RUN touch /etc/subuid /etc/subgid \
    && chmod 666 /etc/subuid /etc/subgid /etc/passwd /etc/group \
    && chmod 777 /var/run

# Copy the Claude CLI binary.
# Default: the bundled binary from claude-agent-sdk.
ARG CLAUDE_CLI=.venv/lib/python3.11/site-packages/claude_agent_sdk/_bundled/claude
COPY ${CLAUDE_CLI} /usr/local/bin/claude
RUN chmod +x /usr/local/bin/claude

# Copy the OpenCode CLI binary for sandboxed OpenCode server mode.
ARG OPENCODE_BIN=opencode
COPY ${OPENCODE_BIN} /usr/local/bin/opencode
RUN chmod +x /usr/local/bin/opencode

# Verify it runs.
RUN /usr/local/bin/claude --version || true
RUN /usr/local/bin/opencode --version || true

ENV HOME=/home/claude
WORKDIR /workspace
